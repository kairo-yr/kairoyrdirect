rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function allowedSuperAdminEmail() {
      return signedIn()
        && request.auth.token.email in [
          '7yr2002@gmail.com',
          'kairobytes@gmail.com'
        ];
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return hasUserDoc() ? userDoc().data.role : null;
    }

    function isSuperAdmin() {
      return allowedSuperAdminEmail() || userRole() == 'super_admin';
    }

    function isAcademyAdmin() {
      return userRole() == 'academy_admin';
    }

    function isCoach() {
      return userRole() == 'coach';
    }

    function isStudent() {
      return userRole() == 'student';
    }

    function isParent() {
      return userRole() == 'parent';
    }

    function userAcademyId() {
      return hasUserDoc() ? userDoc().data.academyId : null;
    }

    function linkedStudentId() {
      return hasUserDoc() ? userDoc().data.linkedStudentId : null;
    }

    function linkedCoachId() {
      return hasUserDoc() ? userDoc().data.linkedCoachId : null;
    }

    function isSameAcademy(academyId) {
      return signedIn() && userAcademyId() == academyId;
    }

    function onlyChanged(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    function validOwnUserCreate(uid) {
      return signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && (
          (
            allowedSuperAdminEmail()
            && request.resource.data.role == 'super_admin'
            && request.resource.data.status == 'active'
            && request.resource.data.academyId == null
          )
          ||
          (
            request.resource.data.role == 'unassigned'
            && request.resource.data.status == 'pending'
            && request.resource.data.academyId == null
          )
        );
    }

    function safeOwnUserUpdate(uid) {
      return signedIn()
        && request.auth.uid == uid
        && onlyChanged(['name', 'photoURL', 'phone', 'updatedAt', 'lastLoginAt']);
    }

    function superAdminBootstrapUpdate(uid) {
      return signedIn()
        && request.auth.uid == uid
        && allowedSuperAdminEmail()
        && request.resource.data.role == 'super_admin'
        && request.resource.data.status == 'active'
        && request.resource.data.academyId == null
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
    }

    function inviteJoinUserUpdate(uid) {
      return signedIn()
        && request.auth.uid == uid
        && resource.data.role == 'unassigned'
        && resource.data.status == 'pending'
        && request.resource.data.role in ['coach', 'student']
        && request.resource.data.status == 'active'
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && onlyChanged([
          'role',
          'status',
          'academyId',
          'linkedCoachId',
          'linkedStudentId',
          'linkedParentId',
          'updatedAt'
        ]);
    }

    function validAcademyRegistrationCreate() {
      return signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == request.auth.token.email
        && request.resource.data.status == 'pending';
    }

    function safeAcademyAdminUpdate(academyId) {
      return isAcademyAdmin()
        && isSameAcademy(academyId)
        && onlyChanged(['name', 'city', 'phone', 'updatedAt']);
    }

    function academyInviteBelongsToUserAcademy() {
      return isSameAcademy(resource.data.academyId);
    }

    function academyInviteCreateBelongsToUserAcademy() {
      return isSameAcademy(request.resource.data.academyId);
    }

    function coachCanWriteAttendance(academyId) {
      return isCoach()
        && isSameAcademy(academyId)
        && request.resource.data.academyId == academyId
        && request.resource.data.coachId == linkedCoachId()
        && get(/databases/$(database)/documents/academies/$(academyId)/batches/$(request.resource.data.batchId)).data.coachId == linkedCoachId()
        && get(/databases/$(database)/documents/academies/$(academyId)/batches/$(request.resource.data.batchId)).data.status == 'active';
    }

    function coachCanWriteClassReport(academyId) {
      return isCoach()
        && isSameAcademy(academyId)
        && request.resource.data.academyId == academyId
        && request.resource.data.coachId == linkedCoachId()
        && get(/databases/$(database)/documents/academies/$(academyId)/batches/$(request.resource.data.batchId)).data.coachId == linkedCoachId()
        && get(/databases/$(database)/documents/academies/$(academyId)/batches/$(request.resource.data.batchId)).data.status == 'active';
    }

    function coachCanWriteProgress(academyId) {
      return isCoach()
        && isSameAcademy(academyId)
        && request.resource.data.academyId == academyId
        && request.resource.data.coachId == linkedCoachId()
        && get(/databases/$(database)/documents/academies/$(academyId)/batches/$(request.resource.data.batchId)).data.coachId == linkedCoachId()
        && get(/databases/$(database)/documents/academies/$(academyId)/batches/$(request.resource.data.batchId)).data.status == 'active'
        && request.resource.data.studentId in get(/databases/$(database)/documents/academies/$(academyId)/batches/$(request.resource.data.batchId)).data.studentIds;
    }

    function coachCanWriteHomework(academyId) {
      return isCoach()
        && isSameAcademy(academyId)
        && request.resource.data.academyId == academyId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByRole == 'coach';
    }

    function inviteAcceptanceUpdate() {
      return signedIn()
        && resource.data.status == 'pending'
        && resource.data.email == request.auth.token.email
        && request.resource.data.status == 'accepted'
        && request.resource.data.acceptedByUid == request.auth.uid
        && onlyChanged(['status', 'acceptedByUid', 'acceptedAt']);
    }

    function studentInviteProfileActivation(academyId, studentId) {
      return isStudent()
        && isSameAcademy(academyId)
        && linkedStudentId() == studentId
        && request.resource.data.status == 'active'
        && request.resource.data.userUid == request.auth.uid
        && onlyChanged(['status', 'userUid', 'updatedAt']);
    }

    function safeLinkedCoachProfileUpdate(academyId, coachId) {
      return isCoach()
        && isSameAcademy(academyId)
        && linkedCoachId() == coachId
        && onlyChanged(['name', 'phone', 'updatedAt']);
    }

    function safeLinkedStudentProfileUpdate(academyId, studentId) {
      return isStudent()
        && isSameAcademy(academyId)
        && linkedStudentId() == studentId
        && onlyChanged([
          'name',
          'phone',
          'guardianName',
          'guardianPhone',
          'guardianEmail',
          'parentName',
          'parentPhone',
          'parentEmail',
          'updatedAt'
        ]);
    }

    match /users/{uid} {
      allow read: if isSuperAdmin() || (signedIn() && request.auth.uid == uid);
      allow create: if isSuperAdmin() || validOwnUserCreate(uid);
      allow update: if isSuperAdmin()
        || safeOwnUserUpdate(uid)
        || superAdminBootstrapUpdate(uid)
        || inviteJoinUserUpdate(uid);
      allow delete: if isSuperAdmin();
    }

    match /academies/{academyId} {
      allow read: if isSuperAdmin() || isSameAcademy(academyId);
      allow create: if isSuperAdmin() || validAcademyRegistrationCreate();
      allow update: if isSuperAdmin() || safeAcademyAdminUpdate(academyId);
      allow delete: if isSuperAdmin();
    }

    match /academies/{academyId}/students/{studentId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (isCoach() && isSameAcademy(academyId))
        || (isStudent() && isSameAcademy(academyId) && linkedStudentId() == studentId);
      allow write: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || studentInviteProfileActivation(academyId, studentId)
        || safeLinkedStudentProfileUpdate(academyId, studentId);
    }

    match /academies/{academyId}/coaches/{coachId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (isCoach() && isSameAcademy(academyId) && linkedCoachId() == coachId);
      allow write: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || safeLinkedCoachProfileUpdate(academyId, coachId);
    }

    match /academies/{academyId}/batches/{batchId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (isCoach() && isSameAcademy(academyId))
        || (
          isStudent()
          && isSameAcademy(academyId)
          && linkedStudentId() in resource.data.studentIds
        );
      allow write: if isSuperAdmin() || (isAcademyAdmin() && isSameAcademy(academyId));
    }

    match /academies/{academyId}/attendance/{attendanceId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (isCoach() && isSameAcademy(academyId))
        || (
          isStudent()
          && isSameAcademy(academyId)
          && linkedStudentId() in resource.data.studentIds
        );
      allow write: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || coachCanWriteAttendance(academyId);
    }

    match /academies/{academyId}/classReports/{reportId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (isCoach() && isSameAcademy(academyId))
        || (
          isStudent()
          && isSameAcademy(academyId)
          && (
            linkedStudentId() in resource.data.studentsPresentIds
            || linkedStudentId() in resource.data.studentsAbsentIds
            || linkedStudentId() in get(/databases/$(database)/documents/academies/$(academyId)/batches/$(resource.data.batchId)).data.studentIds
          )
        );
      allow write: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || coachCanWriteClassReport(academyId);
    }

    match /academies/{academyId}/progressReports/{progressId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (isCoach() && isSameAcademy(academyId))
        || (
          isStudent()
          && isSameAcademy(academyId)
          && resource.data.studentId == linkedStudentId()
        );
      allow write: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || coachCanWriteProgress(academyId);
    }

    match /academies/{academyId}/homework/{homeworkId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (isCoach() && isSameAcademy(academyId))
        || (
          isStudent()
          && isSameAcademy(academyId)
          && (
            linkedStudentId() in resource.data.studentIds
            || linkedStudentId() in get(/databases/$(database)/documents/academies/$(academyId)/batches/$(resource.data.batchId)).data.studentIds
          )
        );
      allow create: if isSuperAdmin()
        || (
          isAcademyAdmin()
          && isSameAcademy(academyId)
          && request.resource.data.academyId == academyId
          && request.resource.data.createdByRole == 'academy_admin'
        )
        || coachCanWriteHomework(academyId);
      allow update: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (
          coachCanWriteHomework(academyId)
          && resource.data.createdByUid == request.auth.uid
        );
      allow delete: if false;
    }

    match /academies/{academyId}/fees/{feeId} {
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && isSameAcademy(academyId))
        || (
          isStudent()
          && isSameAcademy(academyId)
          && resource.data.studentId == linkedStudentId()
        );
      allow write: if isSuperAdmin() || (isAcademyAdmin() && isSameAcademy(academyId));
    }

    match /academyInvites/{inviteId} {
      // TODO: Move invite acceptance to Cloud Functions before production.
      allow read: if isSuperAdmin()
        || (isAcademyAdmin() && academyInviteBelongsToUserAcademy())
        || (signedIn() && resource.data.status == 'pending' && resource.data.email == request.auth.token.email);
      allow create: if isSuperAdmin() || (isAcademyAdmin() && academyInviteCreateBelongsToUserAcademy());
      allow update: if isSuperAdmin()
        || (isAcademyAdmin() && academyInviteBelongsToUserAcademy())
        || inviteAcceptanceUpdate();
      allow delete: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin()
        || (
          isAcademyAdmin()
          && request.resource.data.academyId == userAcademyId()
        )
        || (
          isCoach()
          && request.resource.data.academyId == userAcademyId()
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.action in [
            'academy.attendance.created',
            'academy.attendance.updated',
            'academy.classReport.created',
            'academy.classReport.updated',
            'academy.classReport.submitted',
            'academy.progress.created',
            'academy.progress.updated',
            'academy.homework.created',
            'academy.homework.updated',
            'academy.homework.archived',
            'academy.fee.generated',
            'academy.fee.markedPaid',
            'academy.fee.markedPartial',
            'academy.fee.waived',
            'academy.fee.updated'
          ]
        )
        || (
          signedIn()
          && request.resource.data.action == 'invite.accepted'
          && request.resource.data.actorUid == request.auth.uid
        );
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
